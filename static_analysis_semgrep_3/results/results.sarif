{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Semgrep OSS",
          "version": "1.153.0",
          "rules": [
            {
              "id": "security-reports.semgrep-scan.rules.missing-nosniff-header",
              "shortDescription": {
                "text": "API response may be missing X-Content-Type-Options header. Set 'nosniff' to prevent MIME type sniffing."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.env-variable-direct-access",
              "shortDescription": {
                "text": "Direct access to process.env.ADMIN_SECRET without validation. Environment variables can be undefined at runtime. Use validated configuration or check for undefined values."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.timing-attack-token-comparison",
              "shortDescription": {
                "text": "String comparison of secret value may be vulnerable to timing attacks. Use crypto.timingSafeEqual() for constant-time comparison."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.object-keys-no-hasownproperty",
              "shortDescription": {
                "text": "for...in loop iterates over inherited properties. Use Object.keys(), Object.hasOwn(), or hasOwnProperty() check."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.unsafe-type-assertion-any",
              "shortDescription": {
                "text": "Type assertion to 'any' bypasses TypeScript type checking. This can hide type errors that lead to runtime vulnerabilities."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.insecure-url-construction",
              "shortDescription": {
                "text": "URL constructed from potentially user-controlled input. Validate and sanitize the input to prevent SSRF or open redirect."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.open-redirect-nextresponse",
              "shortDescription": {
                "text": "Redirect with potentially user-controlled URL. Validate the redirect destination to prevent open redirect attacks."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.unsafe-json-parse",
              "shortDescription": {
                "text": "JSON.parse() with external input. Ensure the input is validated and that the parsed result is type-checked before use."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.solana-unvalidated-pubkey",
              "shortDescription": {
                "text": "Solana PublicKey created from potentially user-controlled input. Validate the input is a proper base58 string and handle errors."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.ssrf-dynamic-fetch",
              "shortDescription": {
                "text": "Server-side fetch with potentially user-controlled URL. This may lead to SSRF attacks. Validate and allowlist the URL."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.prisma-raw-query-injection",
              "shortDescription": {
                "text": "Raw SQL query detected via Prisma. If user input is interpolated into the query string, this can lead to SQL injection. Use parameterized queries with Prisma.sql tagged template literals instead."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.file-upload-no-type-check",
              "shortDescription": {
                "text": "File upload via formData without apparent content type validation. Validate file type, size, and content before processing."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.empty-catch-block",
              "shortDescription": {
                "text": "Empty catch block swallows errors silently. At minimum, log the error for debugging purposes."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.session-no-secure-cookie",
              "shortDescription": {
                "text": "Session configuration found. Ensure cookies have secure, httpOnly, and sameSite flags set appropriately."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.buffer-from-string",
              "shortDescription": {
                "text": "Buffer.from with hex encoding. Ensure input is validated as proper hex to prevent unexpected behavior."
              }
            },
            {
              "id": "security-reports.semgrep-scan.rules.debug-console-log",
              "shortDescription": {
                "text": "console.log() found in production code. Excessive logging may leak sensitive information. Use a proper logging framework with appropriate log levels."
              }
            }
          ]
        }
      },
