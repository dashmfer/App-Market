{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Semgrep OSS",
          "rules": [
            {
              "defaultConfiguration": {
                "level": "warning"
              },
              "fullDescription": {
                "text": "Buffer.from with hex encoding. Ensure input is validated as proper hex to prevent unexpected behavior."
              },
              "help": {
                "markdown": "Buffer.from with hex encoding. Ensure input is validated as proper hex to prevent unexpected behavior.",
                "text": "Buffer.from with hex encoding. Ensure input is validated as proper hex to prevent unexpected behavior."
              },
              "id": "security-reports.semgrep-scan.rules.buffer-from-string",
              "name": "security-reports.semgrep-scan.rules.buffer-from-string",
              "properties": {
                "precision": "very-high",
                "tags": [
                  "CWE-20",
                  "security"
                ]
              },
              "shortDescription": {
                "text": "Semgrep Finding: security-reports.semgrep-scan.rules.buffer-from-string"
              }
            },
            {
              "defaultConfiguration": {
                "level": "warning"
              },
              "fullDescription": {
                "text": "console.log() found in production code. Excessive logging may leak sensitive information. Use a proper logging framework with appropriate log levels."
              },
              "help": {
                "markdown": "console.log() found in production code. Excessive logging may leak sensitive information. Use a proper logging framework with appropriate log levels.",
                "text": "console.log() found in production code. Excessive logging may leak sensitive information. Use a proper logging framework with appropriate log levels."
              },
              "id": "security-reports.semgrep-scan.rules.debug-console-log",
              "name": "security-reports.semgrep-scan.rules.debug-console-log",
              "properties": {
                "precision": "very-high",
                "tags": [
                  "CWE-532",
                  "security"
                ]
              },
              "shortDescription": {
                "text": "Semgrep Finding: security-reports.semgrep-scan.rules.debug-console-log"
              }
            },
            {
              "defaultConfiguration": {
                "level": "warning"
              },
              "fullDescription": {
                "text": "Empty catch block swallows errors silently. At minimum, log the error for debugging purposes."
              },
              "help": {
                "markdown": "Empty catch block swallows errors silently. At minimum, log the error for debugging purposes.",
                "text": "Empty catch block swallows errors silently. At minimum, log the error for debugging purposes."
              },
