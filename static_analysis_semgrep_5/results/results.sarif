              "name": "static_analysis_semgrep_5.raw.python-exec-eval",
              "properties": {
                "precision": "very-high",
                "tags": [
                  "CWE-95",
                  "security"
                ]
              },
              "shortDescription": {
                "text": "Semgrep Finding: static_analysis_semgrep_5.raw.python-exec-eval"
              }
            },
            {
              "defaultConfiguration": {
                "level": "warning"
