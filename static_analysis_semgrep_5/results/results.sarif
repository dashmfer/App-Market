                  "snippet": {
                    "text": "    for (const field of TOKEN_FIELDS) {\n      const value = (account as any)[field];\n      if (value && typeof value === \"string\" && !looksEncrypted(value)) {\n        try {\n          updates[field] = encrypt(value);\n          needsUpdate = true;\n        } catch (error) {\n          console.error(\"  Failed to encrypt field for account:\", { field, accountId: account.id, error });\n          errorCount++;\n        }\n      } else if (value && looksEncrypted(value)) {\n        skippedCount++;\n      }\n    }"
