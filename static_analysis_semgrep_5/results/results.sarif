{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Semgrep OSS",
          "rules": [
            {
              "defaultConfiguration": {
                "level": "note"
              },
              "fullDescription": {
                "text": "Assert statements are removed in optimized mode (-O). Do not use for security checks."
              },
              "help": {
                "markdown": "Assert statements are removed in optimized mode (-O). Do not use for security checks.",
                "text": "Assert statements are removed in optimized mode (-O). Do not use for security checks."
              },
              "id": "static_analysis_semgrep_5.raw.python-assert-security",
              "name": "static_analysis_semgrep_5.raw.python-assert-security",
              "properties": {
                "precision": "very-high",
                "tags": [
                  "CWE-617",
                  "security"
                ]
              },
              "shortDescription": {
                "text": "Semgrep Finding: static_analysis_semgrep_5.raw.python-assert-security"
              }
            },
            {
              "defaultConfiguration": {
                "level": "warning"
              },
              "fullDescription": {
                "text": "Debug mode enabled. Ensure this is disabled in production."
              },
              "help": {
                "markdown": "Debug mode enabled. Ensure this is disabled in production.",
                "text": "Debug mode enabled. Ensure this is disabled in production."
              },
              "id": "static_analysis_semgrep_5.raw.python-debug-true",
              "name": "static_analysis_semgrep_5.raw.python-debug-true",
              "properties": {
                "precision": "very-high",
                "tags": [
                  "CWE-489",
                  "security"
                ]
              },
              "shortDescription": {
                "text": "Semgrep Finding: static_analysis_semgrep_5.raw.python-debug-true"
              }
            },
            {
              "defaultConfiguration": {
                "level": "error"
              },
              "fullDescription": {
                "text": "Use of exec() or eval() can execute arbitrary code. Avoid if possible."
              },
              "help": {
                "markdown": "Use of exec() or eval() can execute arbitrary code. Avoid if possible.",
                "text": "Use of exec() or eval() can execute arbitrary code. Avoid if possible."
              },
